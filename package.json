{
  "name": "card-proxying-helper",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox:mv2": "wxt -b firefox --mv2",
    "dev:firefox:mv3": "wxt -b firefox --mv3",
    "build": "wxt build",
    "build:firefox:mv2": "wxt build -b firefox --mv2",
    "build:firefox:mv3": "wxt build -b firefox --mv3",
    "zip": "wxt zip",
    "zip:firefox:mv2": "wxt zip -b firefox --mv2",
    "zip:firefox:mv3": "wxt zip -b firefox --mv3",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "typescript": "^6.0.3",
    "wxt": "^0.20.26"
  }
}
